{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unimak Saha Takip",
  "version": "0.1.3",
  "identifier": "com.unimak.sahatakip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Unimak Saha Takip",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/miko98/Unimak_Saha_Takip/releases/latest/download/latest.json"
      ]
    }
  }
}
